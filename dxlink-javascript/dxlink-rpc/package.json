{
  "name": "@dxfeed/dxlink-rpc",
  "version": "0.8.0",
  "private": false,
  "sideEffects": false,
  "description": "dxLink RPC provides utilities for RPC over dxLink client using rxjs Observable",
  "source": "src/index.ts",
  "exports": {
    "types": "./build/index.d.ts",
    "require": "./build/index.js",
    "default": "./build/index.module.js"
  },
  "main": "build/index.js",
  "module": "build/index.module.js",
  "types": "build/index.d.ts",
  "browserslist": [
    "last 1 year"
  ],
  "minify": {
    "mangle": false
  },
  "scripts": {
    "prepublishOnly": "npm run build && npm run test",
    "build": "microbundle -f esm,cjs",
    "lint": "eslint src",
    "test": "tsx src/index.test.ts",
    "test:watch": "tsx watch src/index.test.ts"
  },
  "dependencies": {
    "@dxfeed/dxlink-core": "0.8.0"
  },
  "peerDependencies": {
    "rxjs": ">=7.0.0"
  },
  "devDependencies": {
    "rxjs": "^7.5.2"
  },
  "author": "Dmitry Petrov <dmitry.petrov@devexperts.com>",
  "maintainers": [
    {
      "name": "Fyzu",
      "url": "https://github.com/fyzu"
    }
  ],
  "license": "MPL-2.0",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/dxfeed/dxlink.git"
  },
  "bugs": {
    "url": "https://github.com/dxfeed/dxlink/issues"
  },
  "homepage": "https://dxfeed.com/",
  "keywords": [
    "api",
    "rpc",
    "client",
    "rxjs",
    "observable",
    "dxfeed",
    "dxlink"
  ],
  "files": [
    "/build",
    "/package.json"
  ]
}
